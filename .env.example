# 应用地址：本地开发保持 localhost，部署后改为正式域名，例如 https://album.example.com
APP_URL=http://localhost:3000

# PostgreSQL 数据库连接串：替换 USER、PASSWORD、HOST、DATABASE
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>

# 登录会话密钥：请生成足够长的随机字符串
SESSION_SECRET=<LONG_RANDOM_SESSION_SECRET>

# 邀请 token 哈希密钥：请生成足够长的随机字符串
INVITE_TOKEN_SECRET=<LONG_RANDOM_INVITE_TOKEN_SECRET>

# 腾讯云 API 密钥 SecretId：在腾讯云访问管理 API 密钥页面获取
TENCENT_CLOUD_SECRET_ID=<TENCENT_CLOUD_SECRET_ID>

# 腾讯云 API 密钥 SecretKey：在腾讯云访问管理 API 密钥页面获取，不能暴露到客户端
TENCENT_CLOUD_SECRET_KEY=<TENCENT_CLOUD_SECRET_KEY>

# 腾讯云 COS 存储桶名称：通常类似 xxx-1250000000
COS_BUCKET=<COS_BUCKET_WITH_APPID>

# 腾讯云 COS 存储桶地域：例如 ap-guangzhou、ap-shanghai
COS_REGION=<COS_REGION>

# COS 对象 key 前缀：用于把本项目上传的文件放到同一目录下，留空使用默认值
COS_UPLOAD_PREFIX=

# 媒体读取签名 URL 有效期，单位秒
COS_SIGNED_URL_EXPIRES_SECONDS=900

# 上传临时授权有效期，单位秒
COS_UPLOAD_CREDENTIAL_EXPIRES_SECONDS=1800

# 初始化全局管理员手机号：填写你自己的手机号
BOOTSTRAP_ADMIN_PHONE=<ADMIN_PHONE>

# 初始化全局管理员显示名
BOOTSTRAP_ADMIN_NAME=管理员

# 初始化全局管理员密码：请填写足够强的密码
BOOTSTRAP_ADMIN_PASSWORD=<STRONG_ADMIN_PASSWORD>
